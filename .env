HUMAN_NEO4J_URI=<your human neo4j uri>
HUMAN_NEO4J_USERNAME=<your human neo4j username>
HUMAN_NEO4J_PASSWORD=<your human neo4j password>

FLY_NEO4J_URI=<your fly neo4j uri>
FLY_NEO4J_USERNAME=<your fly neo4j username>
FLY_NEO4J_PASSWORD=<your fly neo4j password>

LLM_MODEL=<your llm model (e.g. gemini/openai)>
OPENAI_API_KEY=<your openai api key>
GEMINI_API_KEY=<your gemini api key>

JWT_SECRET=<your jwt secret>
SECRET_KEY=<your secret key>

MONGO_URI=<your mongo uri>
APP_PORT=<your app port>
MONGODB_DOCKER_PORT=<your mongodb docker port>

CADDY_PORT=<your caddy port>
CADDY_PORT_FORWARD=<your caddy port forward>

REDIS_URL=<your redis url>
REDIS_EXPIRATION=<your redis expiration>
REDIS_URL_BROKER=<your redis url broker>

ES_URL=<your elasticsearch url>
PARENT_DIR=<your parent directory path>
MORK_URL=<your mork url>